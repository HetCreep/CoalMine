# Dependabot configuration for CoalMine quality assurance
version: 2
updates:
  # Maintain dependencies for npm packages
  - package-ecosystem: "npm"
    directory: "/"
    schedule:
      interval: "weekly" # Weekly to avoid pull request spam (prevents overkill alert fatigue)
    open-pull-requests-limit: 3

  # Maintain dependencies for GitHub Actions
  - package-ecosystem: "github-actions"
    directory: "/"
    schedule:
      interval: "weekly"
    open-pull-requests-limit: 3
